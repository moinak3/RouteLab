{
  "name": "routelab",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "eval": "npm run test && npm run build",
    "eval:golden": "vitest run tests/golden.test.ts",
    "eval:distinct-tasks": "node --import tsx scripts/eval-distinct-tasks.ts",
    "seed": "node --import tsx scripts/export-seed.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.5.2",
    "ajv": "^8.17.1",
    "papaparse": "^5.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "vite": "^6.3.5"
  },
  "devDependencies": {
    "@types/papaparse": "^5.3.16",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  }
}
