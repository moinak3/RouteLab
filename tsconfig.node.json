  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "skipLibCheck": true,
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true
  },
  "include": ["vite.config.ts", "scripts", "src/core", "src/types.ts"]
}
